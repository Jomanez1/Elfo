/* Importamos una fuente amigable y vintage */
@import url('https://fonts.googleapis.com/css2?family=Uncial+Antiqua&family=Varela+Round&display=swap');

:root {
    --bg-color: #1A3D4A; /* El azul-teal oscuro de tu imagen */
    --text-color: #F2E3D5;
    --accent-red: #A6242F;
}

body {
    margin: 0;
    padding: 0;
    font-family: 'Varela Round', sans-serif;
    background-color: var(--bg-color);
    color: var(--text-color);
    display: flex;
    justify-content: center;
    min-height: 100vh;
    /* Añadimos un sutil efecto de grano de papel */
    background-image: url('data:image/svg+xml;base64,');
}

.app-container {
    width: 90%;
    max-width: 1000px;
    text-align: center;
    padding: 20px;
}

header h1 {
    font-family: 'Uncial Antiqua', serif; /* Fuente tipo fantasía */
    color: var(--accent-red);
    margin-bottom: 5px;
}

.main-content {
    display: flex;
    gap: 20px;
    margin-top: 20px;
    flex-wrap: wrap; /* Para móviles */
    justify-content: center;
}

.canvas-container {
    position: relative;
    border: 8px solid #F2E3D5; /* Borde crema tipo marco */
    border-radius: 20px;
    background-color: white; /* El fondo sobre el que pintamos */
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
    overflow: hidden;
    /* Evita que el usuario arrastre la imagen */
    user-select: none; 
}

#elfo-template {
    width: 100%;
    max-width: 500px;
    display: block;
    position: relative;
    z-index: 2; /* Encima del canvas para que el negro no se pinte */
    pointer-events: none; /* Los clics pasan a través de ella */
}

#paintCanvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1; /* Debajo del contorno */
    cursor: crosshair;
}

.palette {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: 15px;
    background: rgba(255,255,255,0.1);
    padding: 20px;
    border-radius: 15px;
    align-items: center;
}

.color-box {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 4px solid transparent;
}

.color-box:hover {
    transform: scale(1.1);
}

.color-box.active {
    border-color: #F2E3D5; /* Resaltar color seleccionado */
    box-shadow: 0 0 10px rgba(255,255,255,0.5);
}

#clearBtn {
    margin-top: 20px;
    padding: 10px 20px;
    background-color: var(--accent-red);
    color: white;
    border: none;
    border-radius: 25px;
    font-size: 16px;
    cursor: pointer;
    font-family: 'Varela Round', sans-serif;
    transition: background 0.2s;
}

#clearBtn:hover {
    background-color: #8c1e26;
}
